{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "globalEnv": ["NODE_ENV"],
  "tasks": {
    "dev": {
      "cache": false,
      "dependsOn": ["^build"],
      "inputs": ["src/**", "tsdown.config.*", "un-api.config.*"]
    },
    "build": {
      "dependsOn": ["^build"]
    }
  }
}
