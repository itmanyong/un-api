{
  "name": "@itmanyong/un-api",
  "version": "0.0.12",
  "private": false,
  "description": "一个自动根据文档构建API请求的解放双手工具库",
  "keywords": [
    "api",
    "api-builder",
    "api-generator",
    "api-swagger",
    "bun-plugin-un-api",
    "esbuild-plugin-un-api",
    "farm-plugin-un-api",
    "generator-api",
    "itemanyong",
    "openapi",
    "rolldown-plugin-un-api",
    "rollup-plugin-un-api",
    "rspack-plugin-un-api",
    "swagger-api",
    "un-api",
    "un-api-builder",
    "vite-plugin-un-api",
    "webpack-plugin-un-api"
  ],
  "homepage": "https://github.com/itmanyong/un-api",
  "bugs": {
    "url": "https://github.com/itmanyong/un-api/issues"
  },
  "license": "MIT",
  "author": {
    "name": "itmanyong",
    "email": "itmanyong@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/itmanyong/un-api.git"
  },
  "files": [
    "build",
    "README.md",
    "CHANGELOG.md"
  ],
  "type": "module",
  "types": "./build/index.d.mts",
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "default": "./build/index.mjs"
    },
    "./browser": {
      "development": "./src/browser/index.ts",
      "default": "./build/browser.mjs"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "exports": {
      ".": "./build/index.mjs",
      "./browser": "./build/browser.mjs",
      "./package.json": "./package.json"
    }
  },
  "scripts": {
    "dev": "tsdown --watch",
    "build": "tsdown",
    "test": "vitest run"
  },
  "dependencies": {
    "es-toolkit": "catalog:",
    "openapi3-ts": "catalog:",
    "unconfig": "catalog:",
    "unplugin": "catalog:"
  }
}