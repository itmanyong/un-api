{
  "name": "@itmanyong/un-api",
  "version": "0.0.1",
  "private": false,
  "description": "一个自动根据文档构建API请求的解放双手工具库",
  "keywords": [],
  "homepage": "https://github.com/itmanyong/un-api#readme",
  "bugs": {
    "url": "https://github.com/itmanyong/un-api/issues"
  },
  "license": "MIT",
  "author": {
    "name": "itmanyong",
    "email": "itmanyong@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/itmanyong/un-api.git"
  },
  "files": [
    "build",
    "../../docs",
    "../../README.md"
  ],
  "type": "module",
  "types": "./build/index.d.mts",
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "default": "./build/index.mjs"
    },
    "./browser": {
      "development": "./src/browser/index.ts",
      "default": "./build/browser.mjs"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "exports": {
      ".": "./build/index.mjs",
      "./browser": "./build/browser.mjs",
      "./package.json": "./package.json"
    }
  },
  "scripts": {
    "dev": "tsdown --watch",
    "build": "tsdown",
    "test": "vitest run"
  },
  "dependencies": {
    "es-toolkit": "catalog:",
    "openapi3-ts": "catalog:",
    "unconfig": "catalog:",
    "unplugin": "catalog:"
  }
}
